# Copy this file to `.env` and fill in real values. Never commit .env to git.

# ─── LLM keys ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Yahoo Finance (for browser-use portfolio sync) ─────────────────────────
# These credentials are used ONLY to read your Yahoo Finance portfolio page.
# NEVER store broker credentials here — Yahoo Finance cannot execute trades,
# which is why it's the only site we allow Gemini to log into.
YAHOO_USERNAME=
YAHOO_PASSWORD=
# Optional: paste the URL of your Yahoo portfolio page here to skip navigation.
YAHOO_PORTFOLIO_URL=

# ─── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then message your new bot and visit
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── ai-hedge-fund location (optional) ──────────────────────────────────────
# Default: ~/ai-hedge-fund
# AI_HEDGE_FUND_DIR=/path/to/ai-hedge-fund
